# =============================================================
# Monterrei Core - configuración de execución
# Copia este ficheiro a `.env` e axusta os valores que precises.
# =============================================================

# Rede ---------------------------------------------------------
# Usa 0.0.0.0 para escoitar en todas as interfaces compartidas (público/admin).
MONTERREI_HOST=0.0.0.0
MONTERREI_HOST_MAIN=192.168.1.126
MONTERREI_HOST_MAIN_EXTRA=192.168.0.2
MONTERREI_PORT_MAIN=8000
MONTERREI_PORT_PUBLIC=8001
# Porto 80 para o público. Require redirección con pfctl (ver setup_port80.command)
MONTERREI_PORT_PUBLIC_LOW=80
MONTERREI_BIND_PORT_80=false

# IP de produción (informativa, só para QR/loggings)
MONTERREI_PROD_IP=192.168.0.2

# Sesións ------------------------------------------------------
MONTERREI_SECRET_KEY=cambia-esta-chave-en-producion
MONTERREI_SESSION_COOKIE=monterrei_sid

# MIDI ---------------------------------------------------------
# Substring para localizar o porto IAC. "IAC" funciona en macOS por defecto.
MONTERREI_MIDI_PORT_HINT=IAC
# Corrección multiplicativa de BPM se Logic envía a metade/dobre. 1.0 = sen corrección
MONTERREI_BPM_DIVIDER=1.0
# Filtro físico
MONTERREI_BPM_MIN=20
MONTERREI_BPM_MAX=400
MONTERREI_BPM_EMA_ALPHA=0.15

# DMX ----------------------------------------------------------
# Substring para localizar o serial do Enttec USB Pro. Baleiro = autodetección
MONTERREI_DMX_PORT_HINT=
MONTERREI_DMX_FPS=30
MONTERREI_DMX_LED_COUNT=60
MONTERREI_DMX_CHANNELS_PER_LED=4

# Recursos -----------------------------------------------------
MONTERREI_M1_VIDEO=castelo_monterrei_1.mp4
MONTERREI_M1_PREVIAS_DIR=static/assets/m1_previas

# Logging ------------------------------------------------------
MONTERREI_LOG_LEVEL=INFO
