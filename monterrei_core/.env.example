# =============================================================
# Monterrei Core - configuración de execución (Ubuntu/Linux)
# Copia este ficheiro a `.env` e axusta os valores que precises.
# =============================================================

# Rede ---------------------------------------------------------
# Usa 0.0.0.0 para escoitar en todas as interfaces compartidas (público/admin).
MONTERREI_HOST=0.0.0.0
# IPs reais nas que escoita o porto principal (músicos/director).
# Se algunha non existe nesta máquina, ignórase con aviso.
MONTERREI_HOST_MAIN=192.168.1.126
MONTERREI_HOST_MAIN_EXTRA=192.168.0.2
MONTERREI_PORT_MAIN=8000
MONTERREI_PORT_PUBLIC=8001
MONTERREI_PORT_ADMIN=8800
# Porto 80 para o público. Require redirección con iptables (ver setup_port80.sh)
MONTERREI_PORT_PUBLIC_LOW=80
MONTERREI_BIND_PORT_80=false

# Auto-abrir admin + proxección no navegador local ao iniciar
MONTERREI_AUTO_OPEN_BROWSER=false

# IP de produción (informativa, só para QR/loggings)
MONTERREI_PROD_IP=192.168.0.2

# Sesións ------------------------------------------------------
MONTERREI_SECRET_KEY=cambia-esta-chave-en-producion
MONTERREI_SESSION_COOKIE=monterrei_sid

# Auth admin/proxección (HTTP Basic) ---------------------------
MONTERREI_ADMIN_USER=xairo
MONTERREI_ADMIN_PASSWORD=xairocampos

# MIDI ---------------------------------------------------------
# Substring para localizar o porto MIDI de entrada.
# Para recibir o metrónomo dun Mac (ex. 192.168.0.3) por rede usa rtpmidid:
#   sudo apt install rtpmidid
#   sudo systemctl enable --now rtpmidid
# No Mac: Audio MIDI Setup -> Window -> Show MIDI Studio -> Network ->
#         engade un Directory entry co IP da máquina Linux e conecta a sesión.
# Despois en Linux aparecerá un porto ALSA chamado 'rtpmidid' co nome do Mac.
MONTERREI_MIDI_PORT_HINT=rtpmidi
MONTERREI_BPM_DIVIDER=1.0
MONTERREI_BPM_MIN=20
MONTERREI_BPM_MAX=400
MONTERREI_BPM_EMA_ALPHA=0.15

# DMX ----------------------------------------------------------
# Substring para localizar o serial do Enttec USB Pro (ex: "ttyUSB", "FT232").
# Baleiro = autodetección.
MONTERREI_DMX_PORT_HINT=
MONTERREI_DMX_FPS=30
MONTERREI_DMX_LED_COUNT=60
MONTERREI_DMX_CHANNELS_PER_LED=4

# Recursos -----------------------------------------------------
MONTERREI_M1_VIDEO=castelo_monterrei_1.mp4
MONTERREI_M1_PREVIAS_DIR=static/assets/m1_previas

# Logging ------------------------------------------------------
MONTERREI_LOG_LEVEL=INFO
